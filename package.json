{
  "name": "@m3ui/vue",
  "version": "0.1.0",
  "description": "Material 3 component library for Vue 3 + Tailwind CSS v4",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fjachuf/m3ui-vue.git"
  },
  "keywords": ["vue", "vue3", "material-design", "material-3", "tailwindcss", "components", "ui"],
  "sideEffects": ["*.css"],
  "main": "./dist/m3ui.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/m3ui.js"
    },
    "./theme": "./src/styles/theme.css",
    "./palettes": "./src/styles/palettes.css"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "pnpm build:js && pnpm build:types && pnpm build:css",
    "build:js": "vite build",
    "build:types": "vue-tsc -p tsconfig.build.json",
    "build:css": "cp -r src/styles dist/",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "vue": "^3.5.0",
    "tailwindcss": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "@tiptap/vue-3": { "optional": true },
    "@tiptap/starter-kit": { "optional": true },
    "@tiptap/extension-placeholder": { "optional": true },
    "@tiptap/extension-underline": { "optional": true },
    "@tiptap/extension-text-align": { "optional": true },
    "@tiptap/extension-link": { "optional": true },
    "@tiptap/extension-image": { "optional": true },
    "@tiptap/extension-color": { "optional": true },
    "@tiptap/extension-text-style": { "optional": true },
    "@tiptap/extension-highlight": { "optional": true },
    "codemirror": { "optional": true },
    "@codemirror/view": { "optional": true },
    "@codemirror/state": { "optional": true },
    "@codemirror/commands": { "optional": true },
    "@codemirror/language": { "optional": true },
    "@codemirror/lang-javascript": { "optional": true },
    "@codemirror/lang-json": { "optional": true },
    "@codemirror/lang-html": { "optional": true },
    "@codemirror/lang-css": { "optional": true },
    "@codemirror/lang-python": { "optional": true },
    "@codemirror/theme-one-dark": { "optional": true },
    "@xterm/xterm": { "optional": true },
    "@xterm/addon-fit": { "optional": true },
    "markdown-it": { "optional": true },
    "chart.js": { "optional": true },
    "vue-chartjs": { "optional": true }
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/tsconfig": "^0.9.1",
    "typescript": "~6.0.3",
    "vite": "^8.0.16",
    "vue": "^3.5.38",
    "vue-tsc": "^3.3.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
