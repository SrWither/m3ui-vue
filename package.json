{
  "name": "@m3ui-vue/m3ui-vue",
  "version": "0.4.5",
  "description": "Material 3 component library for Vue 3 + Tailwind CSS v4",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SrWither/m3ui-vue.git"
  },
  "keywords": [
    "vue",
    "vue3",
    "material-design",
    "material-3",
    "tailwindcss",
    "components",
    "ui"
  ],
  "sideEffects": [
    "*.css"
  ],
  "main": "./dist/m3ui.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/m3ui.js"
    },
    "./chart": {
      "types": "./dist/chart.d.ts",
      "import": "./dist/chart.js"
    },
    "./code-editor": {
      "types": "./dist/code-editor.d.ts",
      "import": "./dist/code-editor.js"
    },
    "./markdown": {
      "types": "./dist/markdown.d.ts",
      "import": "./dist/markdown.js"
    },
    "./rich-text-editor": {
      "types": "./dist/rich-text-editor.d.ts",
      "import": "./dist/rich-text-editor.js"
    },
    "./terminal": {
      "types": "./dist/terminal.d.ts",
      "import": "./dist/terminal.js"
    },
    "./styles": "./dist/styles.css",
    "./theme": "./src/styles/theme.css",
    "./palettes": "./src/styles/palettes.css",
    "./locales": {
      "types": "./dist/locales/index.d.ts",
      "import": "./dist/locales/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "pnpm build:js && pnpm build:types && pnpm build:css",
    "build:js": "vite build && cp dist/m3ui-vue.css dist/styles.css",
    "build:types": "vue-tsc -p tsconfig.build.json",
    "build:css": "cp -r src/styles dist/",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "tailwindcss": "^4.0.0",
    "vue": "^3.5.0"
  },
  "peerDependenciesMeta": {
    "@tiptap/vue-3": {
      "optional": true
    },
    "@tiptap/starter-kit": {
      "optional": true
    },
    "@tiptap/extension-placeholder": {
      "optional": true
    },
    "@tiptap/extension-underline": {
      "optional": true
    },
    "@tiptap/extension-text-align": {
      "optional": true
    },
    "@tiptap/extension-link": {
      "optional": true
    },
    "@tiptap/extension-image": {
      "optional": true
    },
    "@tiptap/extension-color": {
      "optional": true
    },
    "@tiptap/extension-text-style": {
      "optional": true
    },
    "@tiptap/extension-highlight": {
      "optional": true
    },
    "codemirror": {
      "optional": true
    },
    "@codemirror/view": {
      "optional": true
    },
    "@codemirror/state": {
      "optional": true
    },
    "@codemirror/commands": {
      "optional": true
    },
    "@codemirror/language": {
      "optional": true
    },
    "@codemirror/lang-javascript": {
      "optional": true
    },
    "@codemirror/lang-json": {
      "optional": true
    },
    "@codemirror/lang-html": {
      "optional": true
    },
    "@codemirror/lang-css": {
      "optional": true
    },
    "@codemirror/lang-python": {
      "optional": true
    },
    "@codemirror/lang-vue": {
      "optional": true
    },
    "@codemirror/theme-one-dark": {
      "optional": true
    },
    "@xterm/xterm": {
      "optional": true
    },
    "@xterm/addon-fit": {
      "optional": true
    },
    "markdown-it": {
      "optional": true
    },
    "highlight.js": {
      "optional": true
    },
    "chart.js": {
      "optional": true
    },
    "vue-chartjs": {
      "optional": true
    }
  },
  "devDependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-vue": "^0.1.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.1",
    "@lezer/highlight": "^1.2.3",
    "@tiptap/extension-color": "^3.26.1",
    "@tiptap/extension-highlight": "^3.26.1",
    "@tiptap/extension-image": "^3.26.1",
    "@tiptap/extension-link": "^3.26.1",
    "@tiptap/extension-placeholder": "^3.26.1",
    "@tiptap/extension-text-align": "^3.26.1",
    "@tiptap/extension-text-style": "^3.26.1",
    "@tiptap/extension-underline": "^3.26.1",
    "@tiptap/starter-kit": "^3.26.1",
    "@tiptap/vue-3": "^3.26.1",
    "@types/markdown-it": "^14.1.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "chart.js": "^4.5.1",
    "codemirror": "^6.0.2",
    "happy-dom": "^20.10.6",
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.2.0",
    "typescript": "~6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "vue": "^3.5.38",
    "vue-chartjs": "^5.3.3",
    "vue-tsc": "^3.3.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
